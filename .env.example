# ============================================================
# Sentinel Compliance Platform — Environment Variables
# ============================================================
# Copy to .env and fill in your values.
# NEVER commit .env to git.

# ----------------------------------------------------------
# AWS IAM credentials (used by both Nova Act and Bedrock)
# ----------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Or use a named profile instead of key/secret:
# AWS_PROFILE=your-profile-name

# ----------------------------------------------------------
# Nova Act Workflow
# ----------------------------------------------------------
NOVA_ACT_WORKFLOW_NAME=sentinel-scan

# ----------------------------------------------------------
# Legacy Tool URLs (set to Railway public URLs after deploy)
# ----------------------------------------------------------
HRMS_URL=http://localhost:5001
HRMS_USERNAME=admin
HRMS_PASSWORD=admin123

ITADMIN_URL=http://localhost:5002
ITADMIN_USERNAME=admin
ITADMIN_PASSWORD=admin123

PROCUREMENT_URL=http://localhost:5003
PROCUREMENT_USERNAME=admin
PROCUREMENT_PASSWORD=admin123

# ----------------------------------------------------------
# Backend settings
# ----------------------------------------------------------
SCAN_INTERVAL_HOURS=24

# ----------------------------------------------------------
# CORS — set to your Railway frontend URL after deploy
# ----------------------------------------------------------
FRONTEND_URL=http://localhost:5173
